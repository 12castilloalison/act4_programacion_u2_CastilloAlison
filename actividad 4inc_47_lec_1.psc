Algoritmo actividad4_inc_47_lec_
	definir num, contador Como Entero
	contador=1
	escribir "escribe el numero que desee multiplicar"
	leer num
	Mientras  contador < 10 Hacer
		contador=contador+1
		result= num * contador
		escribir num "x" contador "=" result
		
		
	Fin Mientras
FinAlgoritmo
